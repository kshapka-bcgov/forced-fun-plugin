{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/forced-fun-plugin",
	"version": "0.1.0",
	"title": "Forced Fun Block",
	"category": "widgets",
	"icon": "smiley",
	"description": "Display fun text with fun visual content.",
	"example": {},
	"supports": {
		"html": false,
		"color": {
			"text": true,
			"background": true,
			"link": true,
			"gradients": true
		}
	},
	"attributes": {
		"layout": {
			"type": "string",
			"default": "image-left"
		},
		"headingText": {
			"type": "string",
			"default": "Heading placeholder"
		},
		"headingLevel": {
			"type": "string",
			"default": "h3"
		},
		"paragraphText": {
			"type": "string",
			"default": "Paragraph placeholder"
		}
	},
	"allowedBlocks": ["core/button", "core/image", "core/paragraph"],
	"textdomain": "forced-fun-plugin",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
